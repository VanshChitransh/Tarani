# ─── Helius / Solana RPC ───────────────────────────────────────────────────────
# Get a free API key at https://helius.dev
HELIUS_API_KEY=your_key_here
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# ─── Pixel (Next.js app) ───────────────────────────────────────────────────────
# Must be set to the deployed URL on Vercel (e.g. https://your-app.vercel.app)
# Used by the report page for server-side self-fetches to /api/analyze
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Path for the SQLite monitoring DB. On Vercel this defaults to /tmp automatically.
MONITOR_DB_PATH=./monitor.db
# Secret for signing wallet sign-in session cookies (HMAC). REQUIRED in production.
# Generate with: openssl rand -hex 32
AUTH_SECRET=your_auth_secret_here
# RPC endpoint for the wallet adapter's ConnectionProvider (client-side). Sign-in
# never sends a transaction, so the default public RPC is fine. Optional.
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Demo resilience: when "true", /api/analyze falls back to a bundled mint fixture
# (USDC, PYUSD, etc.) if the live RPC fetch fails. Off by default so production
# never silently serves stand-in data. Enable only for demos/screencasts.
DEMO_MODE=false

# ─── Sentinel (background worker) ─────────────────────────────────────────────
# Point at the same DB file as the pixel app when running locally
# MONITOR_DB_PATH=./monitor.db
# How often (ms) the sentinel rechecks tracked mints
SENTINEL_INTERVAL_MS=60000

# ─── Vercel cron (scheduled monitoring) ───────────────────────────────────────
# Secret that protects /api/sentinel/tick. Set the same value in the Vercel
# project env; Vercel sends it as `Authorization: Bearer <CRON_SECRET>` when it
# runs the cron defined in apps/pixel/vercel.json. Leave unset locally to allow
# manual GET triggers. Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
