{
  "name": "tarani",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @tarani/pixel dev",
    "dev:frontend": "bun run --filter @tarani/pixel dev",
    "dev:backend": "bun run --filter @tarani/gilfoyle dev",
    "dev:simulator": "bun run --filter @tarani/kotler dev",
    "dev:sentinel": "bun run apps/sentinel/src/index.ts",
    "build": "bun run --filter @tarani/pixel build && bun run --filter @tarani/gilfoyle build && bun run --filter @tarani/kotler build",
    "lint": "bunx eslint .",
    "format": "bunx prettier --write .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx vitest run",
    "check": "bun run lint && bun run typecheck && bun run test",
    "check:ci": "bun run check && bun run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "helius-sdk": "^2.2.2",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.1",
    "prettier": "^3.6.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "bunx eslint --fix",
      "bunx prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "bunx prettier --write"
    ]
  }
}
