# ─── Helius / Solana RPC ───────────────────────────────────────────────────────
# Get a free API key at https://helius.dev
HELIUS_API_KEY=your_key_here
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# ─── Pixel (Next.js app) ───────────────────────────────────────────────────────
# Must be set to the deployed URL on Vercel (e.g. https://your-app.vercel.app)
# Used by the report page for server-side self-fetches to /api/analyze
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Path for the SQLite monitoring DB. On Vercel this defaults to /tmp automatically.
MONITOR_DB_PATH=./monitor.db

# ─── Sentinel (background worker) ─────────────────────────────────────────────
# Point at the same DB file as the pixel app when running locally
# MONITOR_DB_PATH=./monitor.db
# How often (ms) the sentinel rechecks tracked mints
SENTINEL_INTERVAL_MS=60000
