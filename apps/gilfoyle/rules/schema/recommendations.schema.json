{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tarani.dev/schemas/recommendations.schema.json",
  "title": "Recommendations",
  "description": "Remediation copy mapped to risk-finding ids. Edited as data; loaded by the recommendations engine.",
  "type": "object",
  "additionalProperties": false,
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Matches a RiskFinding id emitted by the risk engine."
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "links": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
